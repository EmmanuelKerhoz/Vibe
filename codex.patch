+          const newLines = [...s.lines];
+          newLines[lineIndex - 1] = {
+            ...newLines[lineIndex - 1],
+            text: mergedText,
+            syllables: mergedText.split(/\s+/).reduce((acc, word) => acc + countSyllables(word), 0),
