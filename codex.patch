+                      text: { type: Type.STRING },
+                      rhymingSyllables: { type: Type.STRING },
+                      rhyme: { type: Type.STRING },
+                      syllables: { type: Type.INTEGER },
+                      concept: { type: Type.STRING }
+                    },
+                    required: ["text", "rhymingSyllables", "rhyme", "syllables", "concept"]
