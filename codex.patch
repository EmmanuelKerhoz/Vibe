+/// <reference types="vite/client" />
+
+interface ImportMetaEnv {
+  readonly VITE_GEMINI_API_KEY?: string;
+  readonly VITE_API_KEY?: string;
+  readonly GEMINI_API_KEY?: string;
+  readonly API_KEY?: string;
+}
+
+interface ImportMeta {
