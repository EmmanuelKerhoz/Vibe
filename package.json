{
  "name": "vibe",
  "private": true,
  "version": "1.21.0.6",
  "type": "module",
  "scripts": {
    "copy-twemoji": "node scripts/copy-twemoji.mjs",
    "dev": "node scripts/copy-twemoji.mjs && vite",
    "prebuild": "node scripts/copy-twemoji.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
