# Variables d'environnement requises pour le projet
# Copiez ce fichier vers .env.local et ajoutez votre clé

# ─── AI Provider ───────────────────────────────────────────────────────────────────
# Fournisseur IA actif. Valeurs: gemini (défaut) | openai | anthropic
AI_PROVIDER=gemini

# Modèle à utiliser (optionnel — remplace le modèle par défaut du fournisseur)
# gemini:    gemini-2.5-flash (défaut)
# openai:    gpt-4o-mini (défaut)
# anthropic: claude-3-5-haiku-20241022 (défaut)
# AI_MODEL=gemini-2.5-flash

# Clés API par fournisseur — seule la clé du fournisseur actif est requise.
# NE PAS préfixer avec VITE_ : ces clés ne doivent jamais être exposées au navigateur.
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Rate Limiter ───────────────────────────────────────────────────────────────────
# Limites (in-memory par défaut, partagé si Upstash configuré)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Upstash Redis — active le rate limiting distribué (partagé entre toutes les instances).
# Sans ces variables, le fallback in-memory est utilisé (acceptable en faible trafic).
# Créer un compte sur https://upstash.com, puis copiez les valeurs depuis le dashboard Redis.
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── G2P Phonemization Microservice ──────────────────────────────────────────────────
# URL du microservice de phonémisation G2P (IPA) - exposé au navigateur
# Pour déploiement Vercel: https://your-app.vercel.app
# Pour développement local: http://localhost:8000
# Définir sur false pour désactiver explicitement le service et forcer le fallback client-side
VITE_PHONEMIZE_ENABLED=true
# Laissez vide pour utiliser uniquement le fallback client-side G2P
VITE_PHONEMIZE_API_URL=

# ─── Spotify ─────────────────────────────────────────────────────────────────────────
# Client ID (public — safe to prefix VITE_)
# Créer une app sur https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Redirect URI (public — doit correspondre exactement à celle déclarée dans le dashboard Spotify)
# Développement local : http://localhost:5173
# Production Vercel  : https://your-app.vercel.app
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173

# Client Secret (privé — NE PAS préfixer VITE_ — utilisé uniquement par api/spotify/*)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
