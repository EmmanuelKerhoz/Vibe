# Vite-exposed key for Gemini AI API calls (recommended)
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional alias consumed by the app as fallback
VITE_API_KEY="MY_GEMINI_API_KEY"

# Legacy/non-Vite fallbacks (kept for compatibility)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
API_KEY="MY_GEMINI_API_KEY"

# App URL (used for links/callbacks in hosted environments)
APP_URL="MY_APP_URL"

# Optional base path for static hosting (e.g. /my-repo/ on GitHub Pages)
VITE_BASE_PATH="/"
