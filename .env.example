# ─────────────────────────────────────────────────────────────────────────────
# Vibe — Environment Variables Reference
# Copy to .env.local and fill in your values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / Gemini ───────────────────────────────────────────────────────────────
# VITE_GEMINI_API_KEY=

# ── Microsoft Graph / OneDrive / OneDrive Business ───────────────────────────
# Azure AD App Registration → Single-page application, PKCE
# Scopes required: Files.Read, User.Read, openid, profile
VITE_MSGRAPH_CLIENT_ID=

# Authority — use 'common' for personal + work accounts, or your tenant ID
# Default: https://login.microsoftonline.com/common
VITE_MSGRAPH_AUTHORITY=https://login.microsoftonline.com/common

# OneDrive Business (SharePoint) — root URL of your tenant
# Format: https://<tenant>.sharepoint.com
# Required only for OneDrive Business picker (ODB). Leave empty for OD personal only.
VITE_SHAREPOINT_ORIGIN=https://your-tenant.sharepoint.com

# ── Dropbox ───────────────────────────────────────────────────────────────────
# Dropbox App Console → Create App → App key
# Chooser domain must be whitelisted in the app settings
VITE_DROPBOX_APP_KEY=

# ── Box ───────────────────────────────────────────────────────────────────────
# Box Developer Console → Create App → OAuth2 → Client ID
# Redirect URI must include: <your-origin>/box-callback
VITE_BOX_CLIENT_ID=

# ── Google Drive ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Enable: Google Picker API + Google Drive API
# OAuth consent screen: scope https://www.googleapis.com/auth/drive.readonly
VITE_GDRIVE_API_KEY=
VITE_GDRIVE_CLIENT_ID=
