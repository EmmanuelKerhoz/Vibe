# ─────────────────────────────────────────────────────────────────────────────
# Vibe — Environment Variables Reference
# Copy to .env.local and fill in your values. Never commit .env.local.
#
# CLIENT-SIDE vars (VITE_ prefix) are bundled into the JS build.
# SERVER-SIDE vars (no VITE_ prefix) are only available to Vercel serverless
# functions — never exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════════════
# SERVER-SIDE — Vercel Serverless Functions only
# Set these in the Vercel dashboard under Project → Settings → Environment Variables
# ════════════════════════════════════════════════════════════════════════════

# ── AI Provider ──────────────────────────────────────────────────────────────
# Which AI backend to use. Accepted values: gemini (default), openai, anthropic
# AI_PROVIDER=gemini

# Optional model override (e.g. gemini-2.5-pro, gpt-4o, claude-opus-4-5)
# AI_MODEL=

# Google Gemini — used by api/_aiProvider.ts and api/lyria/generate.ts
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Lyria music generation uses a SEPARATE Google GenAI key
# (maps to GOOGLE_GENAI_API_KEY in api/lyria/generate.ts)
GOOGLE_GENAI_API_KEY=

# OpenAI — alternative AI provider (api/_aiProvider.ts)
# OPENAI_API_KEY=

# Anthropic — alternative AI provider (api/_aiProvider.ts)
# ANTHROPIC_API_KEY=

# ── Lyria ────────────────────────────────────────────────────────────────────
# Internal auth token for Lyria endpoints (server-side validation)
# Must match VITE_LYRIA_INTERNAL_TOKEN below
LYRIA_INTERNAL_TOKEN=

# ── Suno Music Generation ────────────────────────────────────────────────────
# Mode: 'evolink' (production via Evolink API) or 'dev' (local proxy)
# SUNO_MODE=evolink

# Evolink API key — used when SUNO_MODE=evolink
# EVOLINK_API_KEY=

# Local Suno proxy URL — used when SUNO_MODE=dev
# SUNO_DEV_URL=http://localhost:3001

# Suno session cookie — used when SUNO_MODE=dev
# SUNO_COOKIE=

# ── Copyright Checker ────────────────────────────────────────────────────────
# Genius API token for lyric similarity search
# https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# ── Rate Limiting (optional — Upstash Redis) ─────────────────────────────────
# If unset, rate limiting falls back to in-memory (single-instance only).
# Recommended for production multi-instance deployments.
# https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=60000

# ════════════════════════════════════════════════════════════════════════════
# CLIENT-SIDE — VITE_ prefix, bundled into browser JS
# Set in .env.local for local dev; set in Vercel dashboard for production.
# ════════════════════════════════════════════════════════════════════════════

# ── Lyria (client auth token) ─────────────────────────────────────────────────
# Sent by the client to authorize Lyria API calls. Must match LYRIA_INTERNAL_TOKEN.
VITE_LYRIA_INTERNAL_TOKEN=

# ── Suno (client feature flag) ───────────────────────────────────────────────
# Mirror of SUNO_MODE for the client. Accepted: 'evolink' | 'dev' | '' (disabled)
# VITE_SUNO_MODE=

# ── Spotify ───────────────────────────────────────────────────────────────────
# PKCE OAuth — no secret needed client-side
# https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=

# ── Microsoft Graph / OneDrive / OneDrive Business ───────────────────────────
# Azure AD App Registration → Single-page application, PKCE
# Scopes required: Files.Read, User.Read, openid, profile
VITE_MSGRAPH_CLIENT_ID=

# Authority — use 'common' for personal + work accounts, or your tenant ID
# Default: https://login.microsoftonline.com/common
VITE_MSGRAPH_AUTHORITY=https://login.microsoftonline.com/common

# ── Dropbox ───────────────────────────────────────────────────────────────────
# Dropbox App Console → Create App → App key
VITE_DROPBOX_APP_KEY=

# ── Box ───────────────────────────────────────────────────────────────────────
# Box Developer Console → Create App → OAuth2 → Client ID
VITE_BOX_CLIENT_ID=

# ── Google Drive ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Enable: Google Picker API + Google Drive API
VITE_GDRIVE_API_KEY=
VITE_GDRIVE_CLIENT_ID=

# ── Phonemize Microservice (optional) ────────────────────────────────────────
# Set to 'true' to enable the external Python G2P phonemize service.
# If false/unset, the built-in JS phoneme engine is used.
# VITE_PHONEMIZE_ENABLED=false
# VITE_PHONEMIZE_API_URL=https://your-phonemize-service.example.com
